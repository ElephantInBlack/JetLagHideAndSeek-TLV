---
import "@/styles/globals.css";
import { ToastContainer } from "react-toastify";
// @ts-ignore
import { pwaInfo } from "virtual:pwa-info";

export interface Props {
    className?: string;
}

const { className } = Astro.props;
const baseUrl = import.meta.env.BASE_URL;
const publicUrl = "https://elephantinblack.github.io/JetLagHideAndSeek-TLV";
const assetUrl = (path: string) =>
    `${baseUrl}/${path}`.replace(/([^:]\/)\/+/g, "$1");
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width" />
        <link
            rel="icon"
            type="image/x-icon"
            href={assetUrl("favicon.ico")}
        />
        <link
            rel="shortcut icon"
            type="image/x-icon"
            href={assetUrl("favicon.ico")}
        />
        <link
            rel="apple-touch-icon"
            sizes="180x180"
            href={assetUrl("apple-touch-icon.png")}
        />
        <link
            rel="icon"
            type="image/png"
            sizes="32x32"
            href={assetUrl("favicon-32x32.png")}
        />
        <link
            rel="icon"
            type="image/png"
            sizes="16x16"
            href={assetUrl("favicon-16x16.png")}
        />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.googleapis.com" />
        <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
        <link
            href="https://fonts.googleapis.com/css2?family=Oxygen:wght@300;400;700&family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap"
            rel="stylesheet"
        />
        <meta name="generator" content={Astro.generator} />
        <!-- HTML Meta Tags -->
        <title>Tel Aviv Metro Hide and Seek Map</title>
        <meta
            name="description"
            content="A fast Hide and Seek map for Tel Aviv, Ramat Gan, and Givatayim using bundled local OpenStreetMap data."
        />

        <!-- Facebook Meta Tags -->
        <meta
            property="og:url"
            content={`${publicUrl}/`}
        />
        <meta property="og:type" content="website" />
        <meta
            property="og:title"
            content="Tel Aviv Metro Hide and Seek Map"
        />
        <meta
            property="og:description"
            content="A fast Hide and Seek map for Tel Aviv, Ramat Gan, and Givatayim."
        />
        <meta
            property="og:image"
            content={`${publicUrl}/JLIcon.png`}
        />

        <!-- Twitter Meta Tags -->
        <meta name="twitter:card" content="summary_large_image" />
        <meta property="twitter:domain" content="elephantinblack.github.io" />
        <meta
            property="twitter:url"
            content={`${publicUrl}/`}
        />
        <meta
            name="twitter:title"
            content="Tel Aviv Metro Hide and Seek Map"
        />
        <meta
            name="twitter:description"
            content="A fast Hide and Seek map for Tel Aviv, Ramat Gan, and Givatayim."
        />
        <meta
            name="twitter:image"
            content={`${publicUrl}/JLIcon.png`}
        />

        {pwaInfo && <Fragment set:html={pwaInfo.webManifest.linkTag} />}
    </head>
    <body class:list={[className, "dark"]}>
        <slot />
        <ToastContainer client:only />
    </body>
</html>
